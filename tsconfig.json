{
  "compilerOptions": {
    "strict": true,
    "target": "ES2021",
    "module": "commonjs",
    "noImplicitAny": true,
    "moduleResolution": "node",
    "experimentalDecorators": true,
    "esModuleInterop": true,
    "pretty": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "types": [
      "@types/jest",
      "node"
    ],
    "lib": ["ES2021"],
    "outDir": "./build",
    "rootDir": "./",
    "baseUrl": "./",
    "paths": {
      "@root/*": ["src/*"],
      "@utils/*": ["src/utils/*"]
    },
    "strictPropertyInitialization": true,
    "skipLibCheck": true,
  },
  "exclude": ["node_modules"]
}
